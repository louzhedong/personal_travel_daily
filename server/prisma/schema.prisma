generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TravelScope {
  domestic
  international
}

enum GuideSearchScope {
  domestic
  international
  all
}

enum GuideSearchLogStatus {
  success
  empty
  error
}

enum AccountRole {
  admin
  member
}

enum TripChecklistStage {
  pre_departure
  in_transit
  done
}

enum TripPlanningPriority {
  low
  medium
  high
}

enum TripPlanningStatus {
  planned
  converted
}

enum TripExpenseStatus {
  draft
  actual
}

enum WishlistPriority {
  low
  medium
  high
}

enum MemoryCapsuleType {
  trip
  annual
  companion
}

enum MemoryCapsuleStatus {
  draft
  ready
  archived
}

enum PrivateShareResourceType {
  trip_story
  annual_review
  companion_memory
  memory_capsule
}

enum AssistantSuggestionStatus {
  draft
  confirmed
  dismissed
}

enum GuideSubscriptionKind {
  keyword
  source
  destination
  rss
}

enum GuideSubscriptionRunStatus {
  success
  partial
  error
}

model Account {
  id           String               @id
  name         String
  username     String               @unique
  role         AccountRole          @default(member)
  passwordHash String               @map("password_hash")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  companions   TravelCompanion[]
  trips        Trip[]
  markers      VisitMarker[]
  savedGuides  SavedGuide[]
  histories    GuideSearchHistory[]
  guideSearchLogs GuideSearchLog[]
  companionMemorySnapshots CompanionMemorySnapshot[]
  markerSearchEvents MarkerSearchEvent[]
  sessions     AuthSession[]
  adminAuditLogs AdminAuditLog[] @relation("AdminAuditLogsByAccount")
  tripChecklistItems TripChecklistItem[]
  tripPlanningItems TripPlanningItem[]
  wishlistItems WishlistItem[]
  achievementUnlocks AchievementUnlock[]
  memoryCapsules MemoryCapsule[]
  privateShareLinks PrivateShareLink[]
  photoAlbumPreferences PhotoAlbumPreference[]
  markerTagVocabularies MarkerTagVocabulary[]
  tripExpenses TripExpense[]
  reminderPreferences ReminderPreference[]
  reminderStates ReminderState[]
  homeDashboardPreference HomeDashboardPreference?
  assistantPreference AssistantPreference?
  assistantSuggestions AssistantSuggestion[]
  geoLookups GeoLookup[]
  guideSubscriptions GuideSubscription[]
  exchangeRateSnapshots ExchangeRateSnapshot[]
  accountPreference AccountPreference?

  @@map("accounts")
}

model AccountPreference {
  id                 String   @id
  accountId          String   @unique @map("account_id")
  locale             String   @default("zh-CN")
  mapStyle           String   @default("magazine") @map("map_style")
  defaultCurrency    String   @default("CNY") @map("default_currency")
  commonCurrencies   Json     @map("common_currencies")
  exchangeRateSource String   @default("exchangerate-host") @map("exchange_rate_source")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  account            Account  @relation(fields: [accountId], references: [id])

  @@map("account_preferences")
}

model HomeDashboardPreference {
  id                String   @id
  accountId         String   @unique @map("account_id")
  layoutJson        Json     @map("layout_json")
  hiddenCardIdsJson Json     @map("hidden_card_ids_json")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  account           Account  @relation(fields: [accountId], references: [id])

  @@map("home_dashboard_preferences")
}

model AssistantPreference {
  id        String   @id
  accountId String   @unique @map("account_id")
  style     String   @default("magazine")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  account   Account  @relation(fields: [accountId], references: [id])

  @@map("assistant_preferences")
}

model AssistantSuggestion {
  id             String                    @id
  accountId      String                    @map("account_id")
  contextType    String                    @map("context_type")
  contextId      String?                   @map("context_id")
  style          String                    @default("magazine")
  promptSummary  String                    @map("prompt_summary") @db.Text
  outputJson     Json                      @map("output_json")
  status         AssistantSuggestionStatus @default(draft)
  confirmedAt    DateTime?                 @map("confirmed_at")
  targetKind     String?                   @map("target_kind")
  targetId       String?                   @map("target_id")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")
  account        Account                   @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt], map: "idx_assistant_suggestions_account_created")
  @@index([accountId, contextType], map: "idx_assistant_suggestions_context")
  @@index([status], map: "idx_assistant_suggestions_status")
  @@map("assistant_suggestions")
}

model GeoLookup {
  id            String    @id
  accountId     String    @map("account_id")
  queryKey      String    @map("query_key")
  label         String
  scope         String?
  latitude      Decimal   @db.Decimal(10, 7)
  longitude     Decimal   @db.Decimal(10, 7)
  source        String
  confidence    Int       @default(80)
  rawJson       Json?     @map("raw_json")
  resolvedAt    DateTime  @default(now()) @map("resolved_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  account       Account   @relation(fields: [accountId], references: [id])

  @@unique([accountId, queryKey], map: "uq_geo_lookups_account_query")
  @@index([accountId], map: "idx_geo_lookups_account_id")
  @@map("geo_lookups")
}

model ReminderPreference {
  id          String   @id
  accountId   String   @map("account_id")
  type        String
  enabled     Boolean  @default(true)
  mutedUntil  DateTime? @map("muted_until")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  account     Account  @relation(fields: [accountId], references: [id])

  @@unique([accountId, type], map: "uq_reminder_preferences_account_type")
  @@index([accountId], map: "idx_reminder_preferences_account_id")
  @@index([mutedUntil], map: "idx_reminder_preferences_muted_until")
  @@map("reminder_preferences")
}

model ReminderState {
  id          String   @id
  accountId   String   @map("account_id")
  fingerprint String
  status      String   @default("open")
  resolvedAt  DateTime? @map("resolved_at")
  mutedUntil  DateTime? @map("muted_until")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  account     Account  @relation(fields: [accountId], references: [id])

  @@unique([accountId, fingerprint], map: "uq_reminder_states_account_fingerprint")
  @@index([accountId], map: "idx_reminder_states_account_id")
  @@index([status], map: "idx_reminder_states_status")
  @@index([mutedUntil], map: "idx_reminder_states_muted_until")
  @@index([lastSeenAt], map: "idx_reminder_states_last_seen_at")
  @@map("reminder_states")
}


model MarkerTagVocabulary {
  id        String   @id
  accountId String   @map("account_id")
  value     String
  label     String
  source    String   @default("custom")
  isHidden  Boolean  @default(false) @map("is_hidden")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  account   Account  @relation(fields: [accountId], references: [id])

  @@unique([accountId, value], map: "uq_marker_tag_vocabularies_account_value")
  @@index([accountId], map: "idx_marker_tag_vocabularies_account_id")
  @@index([accountId, isHidden, sortOrder], map: "idx_marker_tag_vocabularies_account_order")
  @@map("marker_tag_vocabularies")
}

model PhotoAlbumPreference {
  id             String   @id
  accountId      String   @map("account_id")
  targetKind     String   @map("target_kind")
  targetId       String   @map("target_id")
  pinnedImageIds Json     @map("pinned_image_ids")
  sortOrderJson  Json     @map("sort_order_json")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  account        Account  @relation(fields: [accountId], references: [id])

  @@unique([accountId, targetKind, targetId], map: "uq_photo_album_preferences_target")
  @@index([accountId], map: "idx_photo_album_preferences_account_id")
  @@map("photo_album_preferences")
}

model MemoryCapsule {
  id         String              @id
  accountId  String              @map("account_id")
  type       MemoryCapsuleType
  targetId   String              @map("target_id")
  title      String
  subtitle   String?             @db.Text
  template   String              @default("editorial")
  status     MemoryCapsuleStatus @default(draft)
  configJson Json                @map("config_json")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  archivedAt DateTime?           @map("archived_at")
  account    Account             @relation(fields: [accountId], references: [id])

  @@index([accountId], map: "idx_memory_capsules_account_id")
  @@index([accountId, type], map: "idx_memory_capsules_account_type")
  @@index([targetId], map: "idx_memory_capsules_target_id")
  @@index([updatedAt], map: "idx_memory_capsules_updated_at")
  @@map("memory_capsules")
}

model PrivateShareLink {
  id                 String                   @id
  accountId          String                   @map("account_id")
  resourceType       PrivateShareResourceType @map("resource_type")
  resourceId         String                   @map("resource_id")
  title              String
  tokenHash          String                   @unique @map("token_hash")
  tokenPreview       String                   @map("token_preview")
  passwordHash       String?                  @map("password_hash")
  expiresAt          DateTime?                @map("expires_at")
  maxAccessCount     Int?                     @map("max_access_count")
  accessCount        Int                      @default(0) @map("access_count")
  revokedAt          DateTime?                @map("revoked_at")
  lastAccessedAt     DateTime?                @map("last_accessed_at")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  account            Account                  @relation(fields: [accountId], references: [id])
  accessLogs         PrivateShareAccessLog[]

  @@index([accountId], map: "idx_private_share_links_account_id")
  @@index([accountId, resourceType], map: "idx_private_share_links_account_resource")
  @@index([resourceType, resourceId], map: "idx_private_share_links_resource")
  @@index([expiresAt], map: "idx_private_share_links_expires_at")
  @@index([revokedAt], map: "idx_private_share_links_revoked_at")
  @@map("private_share_links")
}

model PrivateShareAccessLog {
  id           String           @id
  shareLinkId  String           @map("share_link_id")
  success      Boolean          @default(false)
  failureReason String?         @map("failure_reason")
  ipAddress    String?          @map("ip_address")
  userAgent    String?          @map("user_agent") @db.Text
  accessedAt   DateTime         @default(now()) @map("accessed_at")
  shareLink    PrivateShareLink @relation(fields: [shareLinkId], references: [id])

  @@index([shareLinkId, accessedAt], map: "idx_private_share_access_logs_link_time")
  @@index([accessedAt], map: "idx_private_share_access_logs_accessed_at")
  @@map("private_share_access_logs")
}

model AdminAuditLog {
  id             String   @id
  adminAccountId String   @map("admin_account_id")
  action         String
  targetKind     String?  @map("target_kind")
  targetId       String?  @map("target_id")
  metadataJson   Json?    @map("metadata_json")
  createdAt      DateTime @default(now()) @map("created_at")
  adminAccount   Account  @relation("AdminAuditLogsByAccount", fields: [adminAccountId], references: [id])

  @@index([adminAccountId], map: "idx_admin_audit_logs_admin_account_id")
  @@index([action], map: "idx_admin_audit_logs_action")
  @@index([targetKind, targetId], map: "idx_admin_audit_logs_target")
  @@index([createdAt], map: "idx_admin_audit_logs_created_at")
  @@map("admin_audit_logs")
}

model AchievementUnlock {
  id            String   @id
  accountId     String   @map("account_id")
  achievementId String   @map("achievement_id")
  periodKey     String   @map("period_key")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")
  evidenceJson  Json?    @map("evidence_json")
  account       Account  @relation(fields: [accountId], references: [id])

  @@index([accountId], map: "idx_achievement_unlocks_account_id")
  @@index([achievementId], map: "idx_achievement_unlocks_achievement_id")
  @@unique([accountId, achievementId, periodKey], map: "uq_achievement_unlocks_account_achievement_period")
  @@map("achievement_unlocks")
}

model MarkerSearchEvent {
  id          String             @id
  accountId   String             @map("account_id")
  companionId String?            @map("companion_id")
  keyword     String
  scope       GuideSearchScope
  year        String?
  resultCount Int                @map("result_count")
  page        Int
  pageSize    Int                @map("page_size")
  createdAt   DateTime           @default(now()) @map("created_at")
  account     Account            @relation(fields: [accountId], references: [id])
  companion   TravelCompanion?   @relation(fields: [companionId], references: [id])

  @@index([accountId], map: "idx_marker_search_events_account_id")
  @@index([companionId], map: "idx_marker_search_events_companion_id")
  @@index([createdAt], map: "idx_marker_search_events_created_at")
  @@map("marker_search_events")
}

model Trip {
  id            String        @id
  accountId     String        @map("account_id")
  name          String
  coverImageUrl String?       @map("cover_image_url")
  note          String        @db.Text
  startsAt      DateTime      @map("starts_at")
  endsAt        DateTime      @map("ends_at")
  isDeleted     Boolean       @default(false) @map("is_deleted")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")
  account       Account       @relation(fields: [accountId], references: [id])
  markers       VisitMarker[]
  checklistItems TripChecklistItem[]
  planningItems TripPlanningItem[]
  expenses      TripExpense[]

  @@index([accountId], map: "idx_trips_account_id")
  @@index([startsAt], map: "idx_trips_starts_at")
  @@unique([accountId, name, isDeleted], map: "uq_trips_account_name_active")
  @@map("trips")
}

model AuthSession {
  id         String   @id
  accountId  String   @map("account_id")
  tokenHash  String   @unique @map("token_hash")
  userAgent  String?  @map("user_agent") @db.Text
  ipAddress  String?  @map("ip_address")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  revokedAt  DateTime? @map("revoked_at")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  account    Account  @relation(fields: [accountId], references: [id])

  @@index([accountId], map: "idx_auth_sessions_account_id")
  @@index([expiresAt], map: "idx_auth_sessions_expires_at")
  @@index([lastSeenAt], map: "idx_auth_sessions_last_seen_at")
  @@index([revokedAt], map: "idx_auth_sessions_revoked_at")
  @@map("auth_sessions")
}

model TravelCompanion {
  id         String               @id
  accountId  String               @map("account_id")
  name       String
  color      String
  sortOrder  Int                  @default(0) @map("sort_order")
  isDeleted  Boolean              @default(false) @map("is_deleted")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")
  deletedAt  DateTime?            @map("deleted_at")
  account    Account              @relation(fields: [accountId], references: [id])
  markers    VisitMarker[]
  guides     SavedGuide[]
  histories  GuideSearchHistory[]
  guideSearchLogs GuideSearchLog[]
  memorySnapshots CompanionMemorySnapshot[]
  markerSearchEvents MarkerSearchEvent[]
  tripChecklistItems TripChecklistItem[] @relation("TripChecklistItemCreatedByCompanion")
  tripPlanningItems TripPlanningItem[] @relation("TripPlanningItemCreatedByCompanion")
  wishlistItems WishlistItem[] @relation("WishlistItemCreatedByCompanion")
  tripExpenses TripExpense[]
  tripExpensesPaid TripExpense[] @relation("TripExpensePaidByCompanion")
  tripExpenseSplits TripExpenseSplit[]

  @@index([accountId], map: "idx_travel_companions_account_id")
  @@unique([accountId, name, isDeleted], map: "uq_travel_companions_account_name_active")
  @@map("travel_companions")
}

model TripExpense {
  id                   String            @id
  accountId            String            @map("account_id")
  tripId               String            @map("trip_id")
  companionId          String?           @map("companion_id")
  paidByCompanionId     String?           @map("paid_by_companion_id")
  sourcePlanningItemId String?           @map("source_planning_item_id")
  title                String
  category             String
  amountCents          Int               @map("amount_cents")
  currency             String            @default("CNY")
  originalAmountCents  Int?              @map("original_amount_cents")
  originalCurrency     String?           @map("original_currency")
  baseCurrency         String?           @map("base_currency")
  exchangeRate         Decimal?          @map("exchange_rate") @db.Decimal(18, 8)
  exchangeRateSource   String?           @map("exchange_rate_source")
  exchangeRateAt       DateTime?         @map("exchange_rate_at")
  spentAt              DateTime          @map("spent_at")
  note                 String?           @db.Text
  status               TripExpenseStatus @default(actual)
  isDeleted            Boolean           @default(false) @map("is_deleted")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  deletedAt            DateTime?         @map("deleted_at")
  account              Account           @relation(fields: [accountId], references: [id])
  trip                 Trip              @relation(fields: [tripId], references: [id])
  companion            TravelCompanion?  @relation(fields: [companionId], references: [id])
  paidByCompanion      TravelCompanion?  @relation("TripExpensePaidByCompanion", fields: [paidByCompanionId], references: [id])
  splits               TripExpenseSplit[]

  @@index([accountId], map: "idx_trip_expenses_account_id")
  @@index([tripId], map: "idx_trip_expenses_trip_id")
  @@index([companionId], map: "idx_trip_expenses_companion_id")
  @@index([paidByCompanionId], map: "idx_trip_expenses_paid_by_companion_id")
  @@index([sourcePlanningItemId], map: "idx_trip_expenses_source_planning_item_id")
  @@index([spentAt], map: "idx_trip_expenses_spent_at")
  @@index([status], map: "idx_trip_expenses_status")
  @@map("trip_expenses")
}

model TripExpenseSplit {
  id          String          @id
  expenseId   String          @map("expense_id")
  companionId String          @map("companion_id")
  shareRatio  Decimal         @default(1) @map("share_ratio") @db.Decimal(12, 6)
  shareCents  Int             @map("share_cents")
  createdAt   DateTime        @default(now()) @map("created_at")
  expense     TripExpense     @relation(fields: [expenseId], references: [id])
  companion   TravelCompanion @relation(fields: [companionId], references: [id])

  @@unique([expenseId, companionId], map: "uq_trip_expense_splits_expense_companion")
  @@index([companionId], map: "idx_trip_expense_splits_companion_id")
  @@map("trip_expense_splits")
}

model ExchangeRateSnapshot {
  id           String   @id
  accountId    String   @map("account_id")
  fromCurrency String   @map("from_currency")
  toCurrency   String   @map("to_currency")
  rate         Decimal  @db.Decimal(18, 8)
  source       String
  fetchedAt    DateTime @map("fetched_at")
  createdAt    DateTime @default(now()) @map("created_at")
  account      Account  @relation(fields: [accountId], references: [id])

  @@index([accountId, fromCurrency, toCurrency, fetchedAt], map: "idx_exchange_rate_snapshots_lookup")
  @@map("exchange_rate_snapshots")
}

model VisitMarker {
  id             String             @id
  accountId      String             @map("account_id")
  companionId    String             @map("companion_id")
  tripId         String?            @map("trip_id")
  scope          TravelScope
  scopeId        String             @map("scope_id")
  scopeName      String             @map("scope_name")
  city           String
  note           String             @db.Text
  tags           Json?
  mood           String?
  weather        String?
  transport      String?
  budgetLevel    String?            @map("budget_level")
  latitude       Decimal?           @db.Decimal(10, 7)
  longitude      Decimal?           @db.Decimal(10, 7)
  geoSource      String?            @map("geo_source")
  geoConfidence  Int?               @map("geo_confidence")
  geoResolvedAt  DateTime?          @map("geo_resolved_at")
  isDeleted      Boolean            @default(false) @map("is_deleted")
  visitedStartAt DateTime           @map("visited_start_at")
  visitedEndAt   DateTime           @map("visited_end_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  deletedAt      DateTime?          @map("deleted_at")
  account        Account            @relation(fields: [accountId], references: [id])
  companion      TravelCompanion    @relation(fields: [companionId], references: [id])
  trip           Trip?              @relation(fields: [tripId], references: [id])
  images         VisitMarkerImage[]
  savedGuides    SavedGuide[]
  convertedPlanningItems TripPlanningItem[] @relation("TripPlanningItemConvertedMarker")

  @@index([accountId], map: "idx_visit_markers_account_id")
  @@index([companionId], map: "idx_visit_markers_companion_id")
  @@index([tripId], map: "idx_visit_markers_trip_id")
  @@index([scope, scopeId], map: "idx_visit_markers_scope_scope_id")
  @@index([latitude, longitude], map: "idx_visit_markers_lat_lng")
  @@index([visitedStartAt], map: "idx_visit_markers_visited_start_at")
  @@map("visit_markers")
}

model VisitMarkerImage {
  id               String      @id
  markerId         String      @map("marker_id")
  imageUrl         String      @map("image_url")
  sortOrder        Int         @map("sort_order")
  isFeatured       Boolean     @default(false) @map("is_featured")
  caption          String?     @map("caption")
  curatedSortOrder Int?        @map("curated_sort_order")
  createdAt        DateTime    @default(now()) @map("created_at")
  marker           VisitMarker @relation(fields: [markerId], references: [id])

  @@index([markerId], map: "idx_visit_marker_images_marker_id")
  @@index([isFeatured], map: "idx_visit_marker_images_is_featured")
  @@index([curatedSortOrder], map: "idx_visit_marker_images_curated_sort_order")
  @@unique([markerId, sortOrder], map: "uq_visit_marker_images_marker_sort_order")
  @@map("visit_marker_images")
}

model CompanionMemorySnapshot {
  id                String          @id
  accountId         String          @map("account_id")
  companionId       String          @map("companion_id")
  snapshotVersion   Int             @default(1) @map("snapshot_version")
  payloadJson       Json            @map("payload_json")
  sourceMarkerCount Int             @default(0) @map("source_marker_count")
  sourcePhotoCount  Int             @default(0) @map("source_photo_count")
  sourceGuideCount  Int             @default(0) @map("source_guide_count")
  generatedAt       DateTime        @map("generated_at")
  expiresAt         DateTime        @map("expires_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  account           Account         @relation(fields: [accountId], references: [id])
  companion         TravelCompanion @relation(fields: [companionId], references: [id])

  @@unique([accountId, companionId], map: "uq_companion_memory_snapshots_account_companion")
  @@index([expiresAt], map: "idx_companion_memory_snapshots_expires_at")
  @@map("companion_memory_snapshots")
}

model SavedGuide {
  id                    String          @id
  accountId             String          @map("account_id")
  savedByCompanionId    String          @map("saved_by_companion_id")
  markerId              String?         @map("marker_id")
  saveContextKey        String          @map("save_context_key")
  keyword               String
  guideIdentity         String          @map("guide_identity")
  guideTitle            String          @map("guide_title")
  guideSummary          String          @map("guide_summary") @db.Text
  guideSourceName       String          @map("guide_source_name")
  guideSourceUrl        String          @map("guide_source_url")
  guideCoverImageUrl    String?         @map("guide_cover_image_url")
  guideAuthorName       String?         @map("guide_author_name")
  guidePublishedAt      DateTime?       @map("guide_published_at")
  guideDestinationLabel String?         @map("guide_destination_label")
  guidePayloadJson      Json            @map("guide_payload_json")
  isDeleted             Boolean         @default(false) @map("is_deleted")
  savedAt               DateTime        @map("saved_at")
  deletedAt             DateTime?       @map("deleted_at")
  account               Account         @relation(fields: [accountId], references: [id])
  companion             TravelCompanion @relation(fields: [savedByCompanionId], references: [id])
  marker                VisitMarker?    @relation(fields: [markerId], references: [id])

  @@index([accountId], map: "idx_saved_guides_account_id")
  @@index([savedByCompanionId], map: "idx_saved_guides_companion_id")
  @@index([markerId], map: "idx_saved_guides_marker_id")
  @@unique([savedByCompanionId, saveContextKey, guideIdentity, isDeleted], map: "uq_saved_guides_context_identity_active")
  @@map("saved_guides")
}

model GuideSearchHistory {
  id                String           @id
  accountId         String           @map("account_id")
  companionId       String           @map("companion_id")
  keyword           String
  keywordNormalized String           @map("keyword_normalized")
  scope             GuideSearchScope
  lastResultCount   Int?             @map("last_result_count")
  isDeleted         Boolean          @default(false) @map("is_deleted")
  createdAt         DateTime         @default(now()) @map("created_at")
  deletedAt         DateTime?        @map("deleted_at")
  account           Account          @relation(fields: [accountId], references: [id])
  companion         TravelCompanion  @relation(fields: [companionId], references: [id])

  @@index([accountId], map: "idx_guide_search_histories_account_id")
  @@index([companionId], map: "idx_guide_search_histories_companion_id")
  @@unique([companionId, keywordNormalized, scope, isDeleted], map: "uq_guide_search_histories_scope_keyword_active")
  @@map("guide_search_histories")
}

model GuideSearchLog {
  id                String               @id
  accountId         String               @map("account_id")
  companionId       String               @map("companion_id")
  keyword           String
  keywordNormalized String               @map("keyword_normalized")
  scope             GuideSearchScope
  provider          String
  page              Int
  pageSize          Int                  @map("page_size")
  resultCount       Int                  @map("result_count")
  hasMore           Boolean              @map("has_more")
  durationMs        Int                  @map("duration_ms")
  status            GuideSearchLogStatus
  errorCode         String?              @map("error_code")
  sourceName        String?              @map("source_name")
  sourceDomain      String?              @map("source_domain")
  createdAt         DateTime             @default(now()) @map("created_at")
  account           Account              @relation(fields: [accountId], references: [id])
  companion         TravelCompanion      @relation(fields: [companionId], references: [id])
  qualitySnapshot   GuideQualitySnapshot?

  @@index([accountId, createdAt], map: "idx_guide_search_logs_account_created")
  @@index([keywordNormalized, createdAt], map: "idx_guide_search_logs_keyword_created")
  @@index([sourceDomain, createdAt], map: "idx_guide_search_logs_source_domain_created")
  @@map("guide_search_logs")
}

model GuideSourcePreference {
  id              String   @id
  sourceName      String   @map("source_name")
  sourceDomain    String   @map("source_domain")
  priorityWeight  Int      @default(0) @map("priority_weight")
  demotionReason  String?  @map("demotion_reason") @db.Text
  updatedBy       String?  @map("updated_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([sourceName, sourceDomain], map: "uq_guide_source_preferences_name_domain")
  @@index([priorityWeight], map: "idx_guide_source_preferences_priority")
  @@map("guide_source_preferences")
}

model GuideSourceHealth {
  id                String    @id
  sourceName        String    @map("source_name")
  sourceDomain      String    @map("source_domain")
  recentSuccess     Int       @default(0) @map("recent_success")
  recentFailure     Int       @default(0) @map("recent_failure")
  lastSuccessAt     DateTime? @map("last_success_at")
  lastFailureAt     DateTime? @map("last_failure_at")
  lastFailureReason String?   @map("last_failure_reason") @db.Text
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@unique([sourceName, sourceDomain], map: "uq_guide_source_health_name_domain")
  @@map("guide_source_health")
}

model GuideQualitySnapshot {
  id               String         @id
  logId            String         @unique @map("log_id")
  sourceName       String?        @map("source_name")
  sourceDomain     String?        @map("source_domain")
  score            Int
  level            String
  relevanceScore   Int            @map("relevance_score")
  completenessScore Int           @map("completeness_score")
  readabilityScore Int            @map("readability_score")
  sourceStabilityScore Int        @map("source_stability_score")
  saveRateScore    Int            @map("save_rate_score")
  priorityWeight   Int            @default(0) @map("priority_weight")
  reasonsJson      Json           @map("reasons_json")
  createdAt        DateTime       @default(now()) @map("created_at")
  log              GuideSearchLog @relation(fields: [logId], references: [id])

  @@index([sourceDomain, createdAt], map: "idx_guide_quality_snapshots_source_created")
  @@index([score], map: "idx_guide_quality_snapshots_score")
  @@map("guide_quality_snapshots")
}

model GuideSubscription {
  id           String                 @id
  accountId    String                 @map("account_id")
  kind         GuideSubscriptionKind
  title        String
  keyword      String?
  sourceName   String?                @map("source_name")
  destination  String?
  rssUrl       String?                @map("rss_url") @db.Text
  enabled      Boolean                @default(true)
  lastRunAt    DateTime?              @map("last_run_at")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  account      Account                @relation(fields: [accountId], references: [id])
  runs         GuideSubscriptionRun[]
  items        GuideSubscriptionItem[]

  @@index([accountId], map: "idx_guide_subscriptions_account_id")
  @@index([kind, enabled], map: "idx_guide_subscriptions_kind_enabled")
  @@map("guide_subscriptions")
}

model GuideSubscriptionRun {
  id             String                     @id
  subscriptionId String                     @map("subscription_id")
  status         GuideSubscriptionRunStatus
  matchedCount   Int                        @default(0) @map("matched_count")
  errorMessage   String?                    @map("error_message") @db.Text
  startedAt      DateTime                   @map("started_at")
  finishedAt     DateTime?                  @map("finished_at")
  subscription   GuideSubscription          @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId, startedAt], map: "idx_guide_subscription_runs_subscription_started")
  @@map("guide_subscription_runs")
}

model GuideSubscriptionItem {
  id             String            @id
  subscriptionId String            @map("subscription_id")
  title          String
  sourceName     String?           @map("source_name")
  sourceUrl      String            @map("source_url") @db.Text
  sourceHash     String            @map("source_hash")
  summary        String?           @db.Text
  publishedAt    DateTime?         @map("published_at")
  firstSeenAt    DateTime          @default(now()) @map("first_seen_at")
  savedGuideId   String?           @map("saved_guide_id")
  wishlistItemId String?           @map("wishlist_item_id")
  planningItemId String?           @map("planning_item_id")
  subscription   GuideSubscription @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, sourceHash], map: "uq_guide_subscription_items_subscription_hash")
  @@index([subscriptionId, firstSeenAt], map: "idx_guide_subscription_items_subscription_seen")
  @@map("guide_subscription_items")
}

model TripChecklistItem {
  id                   String             @id
  accountId            String             @map("account_id")
  tripId               String             @map("trip_id")
  createdByCompanionId String             @map("created_by_companion_id")
  title                String
  note                 String?            @db.Text
  stage                TripChecklistStage
  sortOrder            Int                @default(0) @map("sort_order")
  origin               String
  sourceGuideIdentity  String?            @map("source_guide_identity")
  sourceGuideTitle     String?            @map("source_guide_title")
  sourceGuideSourceName String?           @map("source_guide_source_name")
  sourceGuideSourceUrl String?            @map("source_guide_source_url")
  sourceSnippet        String?            @map("source_snippet") @db.Text
  isDeleted            Boolean            @default(false) @map("is_deleted")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  deletedAt            DateTime?          @map("deleted_at")
  account              Account            @relation(fields: [accountId], references: [id])
  trip                 Trip               @relation(fields: [tripId], references: [id])
