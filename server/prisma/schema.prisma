  @@index([accountId], map: "idx_trip_checklist_items_account_id")
  @@index([tripId], map: "idx_trip_checklist_items_trip_id")
  @@index([tripId, stage, sortOrder], map: "idx_trip_checklist_items_trip_stage_sort")
  @@index([tripId, sourceGuideIdentity, isDeleted], map: "idx_trip_checklist_items_trip_guide_identity_active")
  @@map("trip_checklist_items")
}

model TripPlanningItem {
  id                    String               @id
  accountId             String               @map("account_id")
  tripId                String               @map("trip_id")
  createdByCompanionId  String               @map("created_by_companion_id")
  title                 String
  scope                 TravelScope
  scopeId               String               @map("scope_id")
  scopeName             String               @map("scope_name")
  city                  String
  note                  String?              @db.Text
  priority              TripPlanningPriority @default(medium)
  plannedDate           DateTime?            @map("planned_date")
  status                TripPlanningStatus   @default(planned)
  convertedMarkerId     String?              @map("converted_marker_id")
  sourceGuideIdentity   String?              @map("source_guide_identity")
  sourceGuideTitle      String?              @map("source_guide_title")
  sourceGuideSourceName String?              @map("source_guide_source_name")
  sourceGuideSourceUrl  String?              @map("source_guide_source_url")
  sortOrder             Int                  @default(0) @map("sort_order")
  isDeleted             Boolean              @default(false) @map("is_deleted")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  deletedAt             DateTime?            @map("deleted_at")
  account               Account              @relation(fields: [accountId], references: [id])
  trip                  Trip                 @relation(fields: [tripId], references: [id])
  createdByCompanion    TravelCompanion      @relation("TripPlanningItemCreatedByCompanion", fields: [createdByCompanionId], references: [id])
  convertedMarker       VisitMarker?         @relation("TripPlanningItemConvertedMarker", fields: [convertedMarkerId], references: [id])
  sourceWishlistId      String?              @map("source_wishlist_id")
  sourceWishlist         WishlistItem?        @relation("TripPlanningItemSourceWishlist", fields: [sourceWishlistId], references: [id])

  @@index([accountId], map: "idx_trip_planning_items_account_id")
  @@index([tripId], map: "idx_trip_planning_items_trip_id")
  @@index([tripId, status, sortOrder], map: "idx_trip_planning_items_trip_status_sort")
  @@index([createdByCompanionId], map: "idx_trip_planning_items_companion_id")
  @@index([convertedMarkerId], map: "idx_trip_planning_items_converted_marker_id")
  @@index([sourceWishlistId], map: "idx_trip_planning_items_source_wishlist_id")
  @@map("trip_planning_items")
}

model WishlistItem {
  id                    String           @id
  accountId             String           @map("account_id")
  createdByCompanionId  String           @map("created_by_companion_id")
  title                 String
  scope                 TravelScope
  scopeId               String           @map("scope_id")
  scopeName             String           @map("scope_name")
  city                  String
  note                  String?          @db.Text
  priority              WishlistPriority @default(medium)
  targetYear            String?          @map("target_year")
  sourceGuideIdentity   String?          @map("source_guide_identity")
  sourceGuideTitle      String?          @map("source_guide_title")
  sourceGuideSourceName String?          @map("source_guide_source_name")
  sourceGuideSourceUrl  String?          @map("source_guide_source_url")
  isDeleted             Boolean          @default(false) @map("is_deleted")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")
  deletedAt             DateTime?        @map("deleted_at")
  account               Account          @relation(fields: [accountId], references: [id])
  createdByCompanion    TravelCompanion  @relation("WishlistItemCreatedByCompanion", fields: [createdByCompanionId], references: [id])
  planningItems         TripPlanningItem[] @relation("TripPlanningItemSourceWishlist")

  @@index([accountId], map: "idx_wishlist_items_account_id")
  @@index([createdByCompanionId], map: "idx_wishlist_items_companion_id")
  @@index([scope, scopeId], map: "idx_wishlist_items_scope_scope_id")
  @@index([targetYear], map: "idx_wishlist_items_target_year")
  @@map("wishlist_items")
}
