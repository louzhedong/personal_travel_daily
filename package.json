{
  "name": "personal_travel_daily",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "bash scripts/start-local-dev.sh",
    "dev:stop": "bash scripts/stop-local-dev.sh",
    "dev:app-api": "tsx watch server/appApiServer.ts",
    "dev:guide-api": "node server/guideApiServer.mjs",
    "db:generate": "prisma generate --schema server/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema server/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema server/prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema server/prisma/schema.prisma",
    "db:push": "prisma db push --schema server/prisma/schema.prisma",
    "db:seed": "prisma db seed --schema server/prisma/schema.prisma",
    "db:studio": "prisma studio --schema server/prisma/schema.prisma",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --environment jsdom"
  },
  "prisma": {
    "seed": "tsx server/prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^6.16.2",
    "@surbowl/world-geo-json-zh": "^1.0.5",
    "d3-geo": "^3.1.0",
    "fastify": "^5.8.5",
    "mysql2": "^3.22.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.1.0",
    "prisma": "^6.16.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
